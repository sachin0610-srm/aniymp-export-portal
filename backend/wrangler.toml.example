name = "aniymp-quote-api"
main = "quote-worker.js"
compatibility_date = "2026-06-16"

routes = [
  { pattern = "aniymp.com/api/*", zone_name = "aniymp.com" }
]

[[d1_databases]]
binding = "DB"
database_name = "aniymp_quotes"
database_id = "REPLACE_WITH_CLOUDFLARE_D1_DATABASE_ID"

[vars]
MAIL_TO = "info@aniymp.com"
MAIL_FROM = "ANIYMP Website <no-reply@aniymp.com>"
